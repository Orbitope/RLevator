{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "rlevator state and trajectory schemas",
  "$defs": {
    "state": {
      "type": "object",
      "description": "One rlevator state (rung S: F=8 floors, E=3 cars, capacity 8, max queue 12). All-integer state; no x-atol. Mirrors spec.md's state-space table.",
      "properties": {
        "t": {
          "type": "integer",
          "minimum": 0,
          "maximum": 2048
        },
        "pos": {
          "type": "array",
          "minItems": 3,
          "maxItems": 3,
          "items": {
            "type": "integer",
            "minimum": 0,
            "maximum": 112
          }
        },
        "target": {
          "type": "array",
          "minItems": 3,
          "maxItems": 3,
          "items": {
            "type": "integer",
            "minimum": 0,
            "maximum": 7
          }
        },
        "dir": {
          "type": "array",
          "minItems": 3,
          "maxItems": 3,
          "items": {
            "type": "integer",
            "enum": [
              -1,
              1
            ]
          }
        },
        "car_state": {
          "type": "array",
          "minItems": 3,
          "maxItems": 3,
          "items": {
            "type": "integer",
            "minimum": 0,
            "maximum": 4
          }
        },
        "timer": {
          "type": "array",
          "minItems": 3,
          "maxItems": 3,
          "items": {
            "type": "integer",
            "minimum": 0,
            "maximum": 12
          }
        },
        "pending": {
          "type": "array",
          "minItems": 3,
          "maxItems": 3,
          "items": {
            "type": "integer",
            "enum": [
              0,
              3,
              4,
              5
            ]
          }
        },
        "rider_dest": {
          "type": "array",
          "minItems": 3,
          "maxItems": 3,
          "items": {
            "type": "array",
            "minItems": 8,
            "maxItems": 8,
            "items": {
              "type": "integer",
              "minimum": -1,
              "maximum": 7
            }
          }
        },
        "up_count": {
          "type": "array",
          "minItems": 8,
          "maxItems": 8,
          "items": {
            "type": "integer",
            "minimum": 0,
            "maximum": 12
          }
        },
        "down_count": {
          "type": "array",
          "minItems": 8,
          "maxItems": 8,
          "items": {
            "type": "integer",
            "minimum": 0,
            "maximum": 12
          }
        },
        "up_dest": {
          "type": "array",
          "minItems": 8,
          "maxItems": 8,
          "items": {
            "type": "array",
            "minItems": 12,
            "maxItems": 12,
            "items": {
              "type": "integer",
              "minimum": -1,
              "maximum": 7
            }
          }
        },
        "down_dest": {
          "type": "array",
          "minItems": 8,
          "maxItems": 8,
          "items": {
            "type": "array",
            "minItems": 12,
            "maxItems": 12,
            "items": {
              "type": "integer",
              "minimum": -1,
              "maximum": 7
            }
          }
        },
        "up_wait": {
          "type": "array",
          "minItems": 8,
          "maxItems": 8,
          "items": {
            "type": "array",
            "minItems": 12,
            "maxItems": 12,
            "items": {
              "type": "integer",
              "minimum": 0,
              "maximum": 450
            }
          }
        },
        "down_wait": {
          "type": "array",
          "minItems": 8,
          "maxItems": 8,
          "items": {
            "type": "array",
            "minItems": 12,
            "maxItems": 12,
            "items": {
              "type": "integer",
              "minimum": 0,
              "maximum": 450
            }
          }
        }
      },
      "required": [
        "t",
        "pos",
        "target",
        "dir",
        "car_state",
        "timer",
        "pending",
        "rider_dest",
        "up_count",
        "down_count",
        "up_dest",
        "down_dest",
        "up_wait",
        "down_wait"
      ],
      "additionalProperties": false
    },
    "action": {
      "description": "Packed base-6 per-car primitives: car i's command is (a // 6**i) % 6; 0 NOOP, 1 up, 2 down, 3 board-up, 4 board-down, 5 unload.",
      "type": "integer",
      "minimum": 0,
      "maximum": 215
    },
    "trajectory": {
      "type": "object",
      "properties": {
        "metadata": {
          "type": "object",
          "properties": {
            "env": {
              "type": "string"
            },
            "format_version": {
              "type": "string"
            },
            "simulacrum_version": {
              "type": "string"
            },
            "seed": {
              "type": "integer"
            },
            "source": {
              "enum": [
                "reference",
                "batched"
              ]
            },
            "instance": {
              "type": [
                "integer",
                "null"
              ]
            },
            "git_sha": {
              "type": [
                "string",
                "null"
              ]
            },
            "created_at": {
              "type": "string"
            }
          },
          "required": [
            "env",
            "format_version",
            "seed",
            "source",
            "created_at"
          ]
        },
        "initial": {
          "type": "object",
          "properties": {
            "episode": {
              "type": "integer"
            },
            "state": {
              "$ref": "#/$defs/state"
            }
          },
          "required": [
            "episode",
            "state"
          ]
        },
        "steps": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "t": {
                "type": "integer"
              },
              "episode": {
                "type": "integer"
              },
              "state": {
                "$ref": "#/$defs/state"
              },
              "action": {
                "$ref": "#/$defs/action"
              },
              "reward": {
                "type": "number"
              },
              "terminated": {
                "type": "boolean"
              }
            },
            "required": [
              "t",
              "episode",
              "state",
              "action",
              "reward",
              "terminated"
            ]
          }
        }
      },
      "required": [
        "metadata",
        "initial",
        "steps"
      ]
    }
  }
}
